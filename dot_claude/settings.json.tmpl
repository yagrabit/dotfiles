{
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(echo:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(type:*)",
      "Bash(file:*)",
      "Bash(stat:*)",
      "Bash(date:*)",
      "Bash(pwd:*)",
      "Bash(eza:*)",
      "Bash(bat:*)",
      "Bash(fd:*)",
      "Bash(find:*)",
      "Bash(diff:*)",
      "Bash(tree:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(tr:*)",
      "Bash(cut:*)",
      "Bash(awk:*)",
      "Bash(sed:*)",
      "Bash(basename:*)",
      "Bash(dirname:*)",
      "Bash(realpath:*)",
      "Bash(rg:*)",
      "Bash(grep:*)",
      "Bash(fzf:*)",
      "Bash(jq:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git remote:*)",
      "Bash(git rev-parse:*)",
      "Bash(git ls-files:*)",
      "Bash(gh:*)",
      "Bash(chezmoi status:*)",
      "Bash(chezmoi diff:*)",
      "Bash(chezmoi data:*)",
      "Bash(mise:*)",
      "Bash(docker ps:*)",
      "Bash(docker images:*)",
      "Bash(docker inspect:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/pipe-stage-permissions.sh"
          },
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/git-push-reminder.sh"
          },
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/block-no-verify.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/auto-format.sh"
          },
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/typecheck.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/doc-update-reminder.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/pre-compact-log.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/notification-tracker.sh"
          }
        ]
      }
    ]
  },
  "worktree": {
    "symlinkDirectories": [
      ".claude",
      "node_modules",
      ".next",
      "dist",
      ".turbo",
      ".nuxt",
      ".output",
      ".vite",
      "build",
      ".svelte-kit",
      ".parcel-cache"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "python3 {{ .chezmoi.homeDir }}/.claude/statusline-command.py"
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "coderabbit@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "atlassian@claude-plugins-official": true
  },
  "mcpServers": {},
  "effortLevel": "high"
}
