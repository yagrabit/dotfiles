#!/bin/bash
# dotfilesリポジトリのgitフックとエイリアスを設定

DOTFILES_DIR="{{ .chezmoi.sourceDir }}"

if [ -d "$DOTFILES_DIR/.git" ]; then
  cd "$DOTFILES_DIR"

  # .hooksディレクトリをgitフック格納先に設定
  if [ -d ".hooks" ]; then
    git config core.hooksPath .hooks
    echo "gitフックを設定しました"
  fi

  # テンプレートファイル追加用エイリアス（macOS/Linuxでsed構文が異なる）
{{ if eq .chezmoi.os "darwin" }}
  git config alias.add-tmpl '!f() { chezmoi add --template "$1" && src=$(chezmoi source-path "$1") && sed -i "" "s|'"$HOME"'|{{ .chezmoi.homeDir }}|g" "$src" && git add "$src"; }; f'
{{ else }}
  git config alias.add-tmpl '!f() { chezmoi add --template "$1" && src=$(chezmoi source-path "$1") && sed -i "s|'"$HOME"'|{{ .chezmoi.homeDir }}|g" "$src" && git add "$src"; }; f'
{{ end }}
  echo "gitエイリアス add-tmpl を設定しました"
fi
