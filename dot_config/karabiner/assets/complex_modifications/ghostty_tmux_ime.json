{
  "title": "Ghostty tmux IME制御",
  "rules": [
    {
      "description": "GhosttyでCtrl+q押下時にIMEを英数に切り替える",
      "manipulators": [
        {
          "type": "basic",
          "conditions": [
            {
              "type": "frontmost_application_if",
              "bundle_identifiers": ["^com\\.mitchellh\\.ghostty$"]
            }
          ],
          "from": {
            "key_code": "q",
            "modifiers": { "mandatory": ["control"] }
          },
          "to": [
            { "key_code": "japanese_eisuu" },
            { "key_code": "q", "modifiers": ["control"] }
          ]
        }
      ]
    }
  ]
}
