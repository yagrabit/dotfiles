# config.fish - fish shell設定

# 環境変数
set -gx EDITOR nvim
set -gx LANG ja_JP.UTF-8
set -gx GHQ_ROOT ~/ghq

# miseで管理しているツールとHomebrewの競合を防止
set -gx HOMEBREW_FORBIDDEN_FORMULAE node bat eza fd fzf ghq neovim ripgrep starship zoxide

# ユーザーローカルバイナリのPATH追加（ネイティブインストーラー等）
fish_add_path ~/.local/bin

{{ if eq .chezmoi.os "darwin" }}
# macOS固有設定
set -gx PATH /opt/homebrew/bin /opt/homebrew/sbin $PATH
{{ else }}
# Linux Homebrew
set -gx PATH /home/linuxbrew/.linuxbrew/bin $PATH
{{ end }}

# モダンツールのエイリアス
if type -q eza
    alias ls 'eza --icons --git'
    abbr -a ll 'eza --icons --git -l'
    abbr -a la 'eza --icons --git -la'
    abbr -a tree 'eza --icons --tree'
end

if type -q bat
    alias cat 'bat --paging=never'
end

if type -q fd
    alias find 'fd'
end

if type -q rg
    alias grep 'rg'
end

if type -q nvim
    alias vim 'nvim'
    alias vi 'nvim'
end

# zoxide初期化
if type -q zoxide
    zoxide init fish | source
end

# fzf設定
if type -q fzf
    set -gx FZF_DEFAULT_COMMAND 'fd --type f --hidden --follow --exclude .git'
    set -gx FZF_DEFAULT_OPTS '--height 40% --layout=reverse --border'
end

# mise初期化
if type -q mise
    mise activate fish | source
end

# starship初期化
if type -q starship
    starship init fish | source
end

# キーバインド
# Ctrl+G → Ctrl+G: ghqリポジトリ移動
# Ctrl+G → Ctrl+R: ローカルブランチ切り替え
# Ctrl+G → Ctrl+M: リモートブランチ切り替え
# Ctrl+G → Ctrl+S: stash管理
# /: スラッシュコマンド（空バッファ時のみ）
if type -q fzf
    # スラッシュコマンド対象の関数リスト
    set -g SLASH_COMMANDS \
        ghq_fzf_repo \
        fbr fbrm fbrd fbrclean \
        fstash \
        ghq_pull_all \
        groot gwroot \
        gall \
        cc-save cc-restore

    bind \cg\cg ghq_fzf_repo
    bind \cg\cr fbr
    bind \cg\cm fbrm
    bind \cg\cs fstash
    bind / _slash_command_or_insert
end

# tmux自動起動（インタラクティブシェルかつtmux外の場合）
if status is-interactive; and type -q tmux; and not set -q TMUX
{{ if eq .chezmoi.os "darwin" }}
    # macOS: Ghosttyクイックターミナルでは起動しない
    if not set -q GHOSTTY_QUICK_TERMINAL
        tmux new-session -A -s main
    end
{{ else }}
    tmux new-session -A -s main
{{ end }}
end
