# config.fish - fish shell設定

# 環境変数
set -gx EDITOR nvim
set -gx LANG ja_JP.UTF-8
set -gx GHQ_ROOT ~/ghq

# miseで管理しているツールとHomebrewの競合を防止
set -gx HOMEBREW_FORBIDDEN_FORMULAE node bat eza fd fzf ghq neovim ripgrep starship zoxide

# ユーザーローカルバイナリのPATH追加（ネイティブインストーラー等）
fish_add_path ~/.local/bin

{{ if eq .chezmoi.os "darwin" }}
# macOS固有設定（fish_add_pathで重複防止）
fish_add_path /opt/homebrew/bin /opt/homebrew/sbin
{{ else }}
# Linux Homebrew（fish_add_pathで重複防止）
fish_add_path /home/linuxbrew/.linuxbrew/bin
{{ end }}

# モダンツールのエイリアス
if type -q eza
    alias ls 'eza --icons --git'
    abbr -a ll 'eza --icons --git -l'
    abbr -a la 'eza --icons --git -la'
    abbr -a tree 'eza --icons --tree'
end

if type -q bat
    alias cat 'bat --paging=never'
end

if type -q fd
    alias find 'fd'
end

if type -q rg
    alias grep 'rg'
end

if type -q nvim
    alias vim 'nvim'
    alias vi 'nvim'
end

# ツール初期化（キャッシュ付き: バージョン変更時のみ再生成）
# --versionはキャッシュミス判定時のみ実行し、ホットパスのコストを最小化する
function _cached_init
    set -l cmd $argv[1]
    set -l subcmd_args $argv[2..-1]

    if not type -q $cmd
        return
    end

    set -l cache_dir ~/.cache/fish
    set -l cache_file "$cache_dir/$cmd.fish"

    # キャッシュが存在し、バイナリより新しければsourceする（プロセス起動なし）
    set -l cmd_path (command -s $cmd)
    if test -f "$cache_file"; and not test "$cmd_path" -nt "$cache_file"
        source "$cache_file"
        return
    end

    # キャッシュがなければ生成
    mkdir -p -m 700 "$cache_dir"
    if $cmd $subcmd_args > "$cache_file" 2>/dev/null
        source "$cache_file"
    else
        # コマンド失敗時はキャッシュを書かずに直接実行にフォールバック
        rm -f "$cache_file"
        $cmd $subcmd_args | source
    end
end

_cached_init zoxide init fish
_cached_init mise activate fish
_cached_init starship init fish

# fzf設定
if type -q fzf
    set -gx FZF_DEFAULT_COMMAND 'fd --type f --hidden --follow --exclude .git'
    set -gx FZF_DEFAULT_OPTS '--height 40% --layout=reverse --border'
end

# キーバインド
# Ctrl+G → Ctrl+G: ghqリポジトリ移動
# Ctrl+G → Ctrl+R: ローカルブランチ切り替え
# Ctrl+G → Ctrl+M: リモートブランチ切り替え
# Ctrl+G → Ctrl+S: stash管理
# /: スラッシュコマンド（空バッファ時のみ）
if type -q fzf
    # スラッシュコマンド対象の関数リスト
    set -g SLASH_COMMANDS \
        ghq_fzf_repo \
        fbr fbrm fbrd fbrclean \
        fstash \
        ghq_pull_all \
        groot gwroot \
        gall \
        cc-save cc-restore

    bind \cg\cg ghq_fzf_repo
    bind \cg\cr fbr
    bind \cg\cm fbrm
    bind \cg\cs fstash
    bind / _slash_command_or_insert
end

# tmux自動起動はconf.d/tmux-auto-attach.fish.tmplに分離
