#!/bin/bash
# Brewパッケージのインストールスクリプト
# Brewfileの内容が変更されると自動的に再実行される

# Brewfile hash: {{ include "Brewfile" | sha256sum }}

set -eufo pipefail

# brewコマンドへのPATHを設定
{{ if eq .chezmoi.os "darwin" -}}
eval "$(/opt/homebrew/bin/brew shellenv)"
{{ else -}}
eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
{{ end -}}

# brewコマンドの存在確認
if ! command -v brew &>/dev/null; then
  echo "エラー: brewコマンドが見つかりません。先にHomebrewをインストールしてください。"
  exit 1
fi

echo "Brewfile に基づいてパッケージをインストールします..."

# Brewfileを直接参照（--no-upgradeで意図しないアップグレードを防止）
if ! brew bundle --file={{ .chezmoi.sourceDir }}/Brewfile --no-upgrade; then
  echo "エラー: brew bundle に失敗しました。ネットワーク接続を確認してください。"
  exit 1
fi

echo "Brewパッケージのインストールが完了しました。"
